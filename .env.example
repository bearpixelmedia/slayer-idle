# Base44 — copy this file to `.env.local` and fill in values from your app on app.base44.com
# (Project → settings / app URL). Restart `npm run dev` after changing env vars.
#
# Without VITE_BASE44_APP_BASE_URL, the Vite dev proxy stays off and you may see:
#   [base44] Proxy not enabled (VITE_BASE44_APP_BASE_URL not set)

VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Optional; only if your project uses a pinned functions version
# VITE_BASE44_FUNCTIONS_VERSION=
